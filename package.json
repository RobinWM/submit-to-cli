{
  "name": "submit-dir",
  "version": "1.0.3",
  "description": "CLI tool for submitting URLs to aidirs.org",
  "main": "dist/index.js",
  "bin": {
    "submit-dir": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "install.sh"
  ],
  "scripts": {
    "build": "tsc",
    "build:release": "npm run build && pkg dist/index.js --targets node20-linux-x64,node20-linux-arm64,node20-macos-x64,node20-macos-arm64 --output release-assets/submit-dir",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --test tests/*.test.js",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major"
  },
  "keywords": [
    "aidirs",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.20"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.14.0",
    "@yao-pkg/pkg": "^6.14.2",
    "typescript": "^5.4.5"
  },
  "pkg": {
    "outputPath": "release-assets"
  }
}
